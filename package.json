{
  "name": "epstein-archive",
  "private": true,
  "version": "14.5.11",
  "description": "Epstein Archive Analyzer",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prebuild:prod": "bash scripts/ci_pg_nuclear_gates.sh",
    "build:prod": "pnpm --filter @epstein/db build && vite build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production RAW_CORPUS_BASE_PATH=./data node dist/server.js",
    "server": "tsx src/server.ts",
    "api": "tsx src/server.ts",
    "preview": "vite preview",
    "go:prod": "tsx scripts/go_prod.ts",
    "db:migrate:pg": "tsx scripts/pg_migrate.ts && tsx scripts/pg_analyze_after_migrate.ts",
    "db:backfill:pg": "tsx scripts/pg_backfill.ts",
    "db:analyze": "tsx scripts/pg_analyze_after_migrate.ts",
    "seed:structure": "tsx scripts/ensure_structure.ts",
    "verify": "tsx scripts/verify_ops.ts",
    "verify:post-deploy": "./scripts/post_deploy_verify.sh",
    "seed:sascha-investigation": "tsx scripts/create_sascha_investigation.ts",
    "seed:katie-videos": "KJ_VIDEO_ROOT=./data/media/videos/KatieJohnson tsx scripts/ingest_katie_videos.ts",
    "db:merge": "tsx scripts/sync-db.ts",
    "db:push": "./deploy.sh --db-only",
    "ingest:intelligence": "tsx scripts/ingest_intelligence.ts",
    "black-book:enrich": "tsx scripts/enrich_black_book.ts",
    "media:thumbnails:backfill": "tsx scripts/backfill_thumbnails.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "check:boundaries": "node scripts/check_client_server_boundary.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "token:check": "tsx scripts/token_compliance.ts",
    "test:smoke": "tsx scripts/smoke-tests.ts",
    "test:email:smoke": "tsx scripts/email_smoke.ts",
    "test:contracts": "playwright test tests/api-dto-contract.spec.ts --project=chromium --workers=1",
    "test:route-sync": "playwright test tests/route-ui-sync.spec.ts --project=chromium --workers=1",
    "test:e2e": "playwright test",
    "deploy:prod": "./deploy.sh",
    "audit:pg": "bash scripts/run_audit_suite.sh",
    "ci:pg:nuclear": "bash scripts/ci_pg_nuclear_gates.sh",
    "db:check": "node -e 'const { Client } = require(\"pg\"); const client = new Client({ connectionString: process.env.DATABASE_URL }); client.connect().then(() => { console.log(\"✅ DB OK\"); client.end(); process.exit(0); }).catch((e) => { console.error(\"❌ DB Fail:\", e.message); process.exit(1); });'",
    "schema:hash:check": "tsx scripts/pg_schema_hash.ts check",
    "schema:hash:update": "tsx scripts/pg_schema_hash.ts update",
    "prepare": "husky",
    "test": "playwright test"
  },
  "dependencies": {
    "@epstein/db": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/d3-quadtree": "^3.0.6",
    "@types/diff": "^8.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/quoted-printable": "^1.0.2",
    "@types/react-window-infinite-loader": "^1.0.9",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.0",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.0",
    "clsx": "^2.1.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "d3-quadtree": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "date-fns": "^3.3.1",
    "diff": "^8.0.3",
    "dotenv": "^16.4.5",
    "exif-parser": "^0.1.12",
    "express": "^4.21.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^11.0.8",
    "fuse.js": "^7.0.0",
    "glob": "^13.0.0",
    "helmet": "^8.1.0",
    "html-entities": "^2.6.0",
    "html-to-text": "^9.0.5",
    "jsdom": "^27.3.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "mailparser": "^3.9.3",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "open": "^11.0.0",
    "pg": "^8.18.0",
    "quoted-printable": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-leaflet": "^4.2.1",
    "react-pdf": "^10.2.0",
    "react-router-dom": "^6.22.3",
    "react-virtualized-auto-sizer": "^2.0.2",
    "react-window": "^1.8.10",
    "react-window-infinite-loader": "^2.0.0",
    "recharts": "^2.12.3",
    "sharp": "^0.33.5",
    "toobusy-js": "^0.5.1",
    "tsx": "^4.19.2",
    "zod": "^3.23.8",
    "tailwind-merge": "^2.2.1",
    "tesseract.js": "^7.0.0"
  },
  "optionalDependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/express": "^5.0.0",
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/node-cache": "^4.1.3",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-virtualized-auto-sizer": "^1.0.8",
    "@types/react-window": "^1.8.8",
    "@types/toobusy-js": "^0.5.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "node-pg-migrate": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.9.0",
    "vite": "^7.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "sharp",
      "tesseract.js"
    ]
  }
}
