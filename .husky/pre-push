#!/bin/sh


echo "Running quality checks"
echo "🔍 Running linter..."
pnpm lint:fix || exit 1

echo "🔍 Running type-checker..."
pnpm type-check || exit 1

echo "🔍 Checking database integrity..."
pnpm db:check || exit 1

# Check for uncommitted changes (dirty state) caused by formatter or otherwise
if [ -n "$(git status --porcelain)" ]; then
    echo "❌ Error: Found uncommitted changes after quality checks."
    echo "Please commit these changes before pushing:"
    git status --short
    exit 1
fi

echo "✅ Pre-push check passed."
